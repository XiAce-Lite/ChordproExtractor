<Window x:Class="ChordproExtractor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chordpro Extractor（Chordino + 歌詞コピペマージ）"
        Height="760"
        Width="1180"
        MinHeight="560"
        MinWidth="960"
        Background="#F5F5F7">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="260" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 上部: ファイル選択 -->
        <Border Grid.Row="0"
                Padding="12"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D0D0D8"
                BorderThickness="1"
                Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BrowseButton"
                            Content="音声ファイルを選択…"
                            Padding="12,6"
                            MinWidth="180"
                            Click="BrowseButton_Click" />
                    <TextBlock VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               Foreground="#555"
                               Text="または下に MP3 / WAV をドロップ" />
                </StackPanel>
                <Border Grid.Row="1"
                        x:Name="DropZoneBorder"
                        AllowDrop="True"
                        Background="#FAFAFC"
                        BorderBrush="#C8C8D0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        DragOver="DropZone_DragOver"
                        Drop="DropZone_Drop">
                    <TextBox x:Name="AudioPathTextBox"
                             IsReadOnly="True"
                             AllowDrop="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Center"
                             MinHeight="36"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#222"
                             ToolTip="選択された音声ファイルのフルパス"
                             DragOver="DropZone_DragOver"
                             Drop="DropZone_Drop" />
                </Border>
            </Grid>
        </Border>

        <!-- 操作バー -->
        <Border Grid.Row="1"
                Padding="12,10"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D0D0D8"
                BorderThickness="1"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#333" Text="BPM" />
                    <TextBox x:Name="BpmTextBox"
                             Width="80"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             Text=""
                             ToolTip="4/4 想定でコード行は 4 小節ごとに改行。空欄で変換すると自動検出し、ここに反映します。" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ConvertButton"
                            Content="解析（BPM + コード）"
                            Padding="14,8"
                            MinWidth="160"
                            Margin="0,0,8,0"
                            Click="ConvertButton_Click" />
                    <Button x:Name="CancelButton"
                            Content="キャンセル"
                            Padding="14,8"
                            MinWidth="100"
                            IsEnabled="False"
                            Click="CancelButton_Click" />
                </StackPanel>
                <Button x:Name="MergeLyricsAndChordsButton"
                        Grid.Column="3"
                        Content="歌詞とコードを行単位でマージ"
                        Padding="16,8"
                        MinWidth="260"
                        HorizontalAlignment="Right"
                        Click="MergeLyricsAndChordsButton_Click"
                        ToolTip="左の歌詞と中央のコード行を上から対応させ、コード行上の [コード] の位置比率に合わせて歌詞へ挿入し、右に Chordpro を出力します。" />
            </Grid>
        </Border>

        <!-- 3 カラム -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" MinWidth="220" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="10"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#D0D0D8"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="歌詞（コピペ）"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="LyricsTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontSize="13"
                             Padding="8"
                             BorderBrush="#C8C8D0"
                             BorderThickness="1"
                             Background="#FFFFFA"
                             ToolTip="ネットなどからコピーした歌詞を貼り付け。1 行がマージ時に左カラムの 1 行と対応します。" />
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="10"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#D0D0D8"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="自動解析コード（1 行 ≒ 4 小節）"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="ChordLinesTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas,Cascadia Mono,monospace"
                             FontSize="13"
                             Padding="8"
                             BorderBrush="#C8C8D0"
                             BorderThickness="1"
                             Background="#F8FAFF"
                             ToolTip="「解析」実行後に Chordino の結果が入ります。必要なら手で直せます。" />
                </DockPanel>
            </Border>

            <Border Grid.Column="4"
                    Padding="10"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#D0D0D8"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Chordpro 出力（マージ後）"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="ChordproOutputTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas,Cascadia Mono,monospace"
                             FontSize="13"
                             Padding="8"
                             BorderBrush="#C8C8D0"
                             BorderThickness="1"
                             Background="#FFFCF8"
                             ToolTip="マージボタンで生成。保存はこの内容です。" />
                </DockPanel>
            </Border>
        </Grid>

        <!-- 下部: 進捗・保存 -->
        <Border Grid.Row="3"
                Padding="12"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D0D0D8"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
                    <TextBlock x:Name="DurationLabel"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               Foreground="#555"
                               Text="長さ: —" />
                    <TextBlock x:Name="StatusLabel"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="#333"
                               Text="音声を選び「解析」でコード行を生成。歌詞を貼ってからマージしてください。" />
                    <Button x:Name="SaveButton"
                            DockPanel.Dock="Right"
                            Content=".chordpro / .pro として保存…"
                            Padding="16,8"
                            MinWidth="220"
                            Margin="16,0,0,0"
                            Click="SaveButton_Click" />
                </DockPanel>
                <StackPanel Grid.Row="1" Orientation="Vertical">
                    <TextBlock Text="進捗" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ProgressBar x:Name="MainProgressBar"
                                 Height="22"
                                 Minimum="0"
                                 Maximum="100"
                                 IsIndeterminate="False" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
