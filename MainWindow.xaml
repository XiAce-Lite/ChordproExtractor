<Window x:Class="ChordproExtractor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ChordproExtractor"
        Title="Chordpro Extractor（Chordino + 1クリック挿入エディタ）"
        Height="760"
        Width="1180"
        MinHeight="560"
        MinWidth="960"
        Background="#F5F5F7"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="260" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 上部: ファイル選択 -->
        <Border Grid.Row="0"
                Padding="12"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D0D0D8"
                BorderThickness="1"
                Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BrowseButton"
                            Content="音声ファイルを選択…"
                            Padding="12,6"
                            MinWidth="180"
                            Click="BrowseButton_Click" />
                    <TextBlock VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               Foreground="#555"
                               Text="または下に MP3 / WAV をドロップ" />
                </StackPanel>
                <Border Grid.Row="1"
                        x:Name="DropZoneBorder"
                        AllowDrop="True"
                        Background="#FAFAFC"
                        BorderBrush="#C8C8D0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        DragOver="DropZone_DragOver"
                        Drop="DropZone_Drop">
                    <TextBox x:Name="AudioPathTextBox"
                             IsReadOnly="True"
                             AllowDrop="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Center"
                             MinHeight="36"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#222"
                             ToolTip="選択された音声ファイルのフルパス"
                             DragOver="DropZone_DragOver"
                             Drop="DropZone_Drop" />
                </Border>
            </Grid>
        </Border>

        <!-- 操作バー -->
        <Border Grid.Row="1"
                Padding="12,10"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D0D0D8"
                BorderThickness="1"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#333" Text="BPM" />
                    <TextBox x:Name="BpmTextBox"
                             Width="80"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             Text=""
                             ToolTip="Chordpro ヘッダ用。空欄で解析時に自動検出。" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ConvertButton"
                            Content="解析（BPM + コード）"
                            Padding="14,8"
                            MinWidth="160"
                            Margin="0,0,8,0"
                            Click="ConvertButton_Click" />
                    <Button x:Name="CancelButton"
                            Content="キャンセル"
                            Padding="14,8"
                            MinWidth="100"
                            IsEnabled="False"
                            Click="CancelButton_Click" />
                </StackPanel>
                <Button x:Name="UpdateChordproPreviewButton"
                        Grid.Column="3"
                        Content="Chordpro プレビュー更新"
                        Padding="16,8"
                        MinWidth="200"
                        HorizontalAlignment="Right"
                        Click="UpdateChordproPreviewButton_Click"
                        ToolTip="歌詞（インラインコード含む）に Chordpro 用ヘッダを付け、右のプレビュー欄を上書きします。保存はプレビュー欄の内容です。" />
            </Grid>
        </Border>

        <!-- 歌詞 | コードパレット | Chordpro プレビュー -->
        <Grid x:Name="MainEditorGrid" Grid.Row="2" Margin="0,0,0,10">
            <!-- 3 列とも * 幅にし、各スプリッターが「左右の列だけ」をリサイズ（Auto 列は星列と干渉して狭まる） -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColLyrics" Width="2*" MinWidth="200" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition x:Name="ColPalette" Width="1.15*" MinWidth="220" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition x:Name="ColPreview" Width="1.35*" MinWidth="180" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="10"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#D0D0D8"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="歌詞（編集・コード挿入先）"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="LyricsTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontSize="13"
                             Padding="8"
                             BorderBrush="#C8C8D0"
                             BorderThickness="1"
                             Background="#FFFFFA"
                             ToolTip="ネットなどからコピーした歌詞を貼り付け、カーソル位置に右パレットのコードをクリックで挿入します。" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="False"
                          Background="#D0D0D8" />

            <Border Grid.Column="2"
                    Padding="10"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#D0D0D8"
                    BorderThickness="1"
                    MinWidth="220">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="コードパレット（解析後・クリックで挿入）"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"
                               TextWrapping="Wrap" />
                    <TextBlock DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Foreground="#666"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="挿入は歌詞のキャレット位置に行われます。プレビュー欄は手編集できます。歌詞とプレビューを揃えるときは「Chordpro プレビュー更新」を押してください。" />
                    <ListBox x:Name="ChordPaletteList"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0,0,0,2" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:ChordPaletteItemVm}">
                                    <Button Click="ChordPaletteInsertButton_Click"
                                            Padding="8,6"
                                            Margin="0,0,0,4"
                                            HorizontalContentAlignment="Stretch"
                                            ToolTip="{Binding ToolTipText}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Label}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CheckGlyph}"
                                                       MinWidth="22"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="DarkGreen"
                                                       FontSize="14"
                                                       FontWeight="SemiBold" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="6"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="False"
                          Background="#D0D0D8" />

            <Border Grid.Column="4"
                    Padding="10"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#D0D0D8"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Chordpro プレビュー（編集可・保存対象）"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="ChordproOutputTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas,Cascadia Mono,monospace"
                             FontSize="13"
                             Padding="8"
                             BorderBrush="#C8C8D0"
                             BorderThickness="1"
                             Background="#FFFCF8"
                             ToolTip="ここを直接編集しても構いません。「Chordpro プレビュー更新」で歌詞＋ヘッダから上書きできます。保存はこの欄の内容です。" />
                </DockPanel>
            </Border>
        </Grid>

        <!-- 下部: 進捗・保存 -->
        <Border Grid.Row="3"
                Padding="12"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D0D0D8"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
                    <TextBlock x:Name="DurationLabel"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               Foreground="#555"
                               Text="長さ: —" />
                    <TextBlock x:Name="StatusLabel"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="#333"
                               Text="音声を選び「解析」でコードパレットを生成。歌詞にカーソルを置き、コードをクリックで挿入してください。" />
                    <Button x:Name="SaveButton"
                            DockPanel.Dock="Right"
                            Content=".chordpro / .pro として保存…"
                            Padding="16,8"
                            MinWidth="220"
                            Margin="16,0,0,0"
                            Click="SaveButton_Click" />
                </DockPanel>
                <StackPanel Grid.Row="1" Orientation="Vertical">
                    <TextBlock Text="進捗" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ProgressBar x:Name="MainProgressBar"
                                 Height="22"
                                 Minimum="0"
                                 Maximum="100"
                                 IsIndeterminate="False" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
