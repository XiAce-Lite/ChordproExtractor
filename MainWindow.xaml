<Window x:Class="ChordproExtractor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chordpro Extractor (Sonic Annotator / Chordino)"
        Height="640"
        Width="960"
        MinHeight="480"
        MinWidth="720"
        Background="#F5F5F7">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="200" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 上部: ファイル選択 -->
        <Border Grid.Row="0"
                Padding="12"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D0D0D8"
                BorderThickness="1"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BrowseButton"
                            Content="音声ファイルを選択…"
                            Padding="12,6"
                            MinWidth="180"
                            Click="BrowseButton_Click" />
                    <TextBlock VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Foreground="#555"
                               Text="または下のエリアに MP3 / WAV をドロップ" />
                </StackPanel>
                <Border Grid.Row="1"
                        x:Name="DropZoneBorder"
                        AllowDrop="True"
                        Background="#FAFAFC"
                        BorderBrush="#C8C8D0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        DragOver="DropZone_DragOver"
                        Drop="DropZone_Drop">
                    <TextBox x:Name="AudioPathTextBox"
                             IsReadOnly="True"
                             AllowDrop="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Center"
                             MinHeight="36"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#222"
                             ToolTip="選択された音声ファイルのフルパス"
                             DragOver="DropZone_DragOver"
                             Drop="DropZone_Drop" />
                </Border>
            </Grid>
        </Border>

        <!-- 中央: 2カラム -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- 左: 実行・進捗 -->
            <Border Grid.Column="0"
                    Padding="12"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#D0D0D8"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="変換" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Button x:Name="ConvertButton"
                            Content="Chordino で変換"
                            Padding="12,10"
                            HorizontalAlignment="Stretch"
                            Click="ConvertButton_Click" />
                    <TextBlock x:Name="DurationLabel"
                               Margin="0,12,0,4"
                               Foreground="#555"
                               Text="長さ: —" />
                    <TextBlock Text="進捗" FontWeight="SemiBold" Margin="0,16,0,6" />
                    <ProgressBar x:Name="MainProgressBar"
                                 Height="22"
                                 Minimum="0"
                                 Maximum="100"
                                 IsIndeterminate="False" />
                    <TextBlock x:Name="StatusLabel"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="#333"
                               Text="音声を選んで「Chordino で変換」を押してください。" />
                </StackPanel>
            </Border>

            <!-- 右: Chordpro スケルトン -->
            <Border Grid.Column="2"
                    Padding="12"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#D0D0D8"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Chordpro スケルトン（編集可）"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBox x:Name="ChordproTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas,Cascadia Mono,monospace"
                             FontSize="13"
                             Padding="8"
                             BorderBrush="#C8C8D0"
                             BorderThickness="1"
                             Background="#FFFCF8" />
                </DockPanel>
            </Border>
        </Grid>

        <!-- 下部: 保存 -->
        <Border Grid.Row="2"
                Padding="12"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D0D0D8"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SaveButton"
                        Content=".chordpro / .pro として保存…"
                        Padding="16,8"
                        MinWidth="220"
                        Click="SaveButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
